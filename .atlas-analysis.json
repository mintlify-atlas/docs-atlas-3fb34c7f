  "keyFeatures": [
    "Full async/await support with asyncio",
    "Plugin-based broker system (Redis, RabbitMQ, NATS, ZeroMQ, etc.)",
    "FastAPI-style dependency injection for tasks",
    "Built-in task scheduler with cron and interval support",
    "Middleware hooks for pre/post task execution",
    "InMemoryBroker for local development and testing",
    "Hot-reload for workers during development",
    "OpenTelemetry instrumentation support",
    "Type-safe task definitions with PEP-612 ParamSpec",
    "Multiple serialization formats (JSON, msgpack, cbor, orjson)"
  ],
